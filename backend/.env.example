MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=vendorbridge_db
SECRET_KEY=change-this-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SMTP — required for real invoice email delivery
# Gmail example: use an App Password (Google Account > Security > 2-Step Verification > App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=VendorBridge <your-email@gmail.com>
SMTP_USE_TLS=true
